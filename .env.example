# Copie para .env e preencha. Em produção (Render/AWS) defina como variáveis do host.
SECRET_KEY=troque-por-uma-chave-segura
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Domínio público em produção (ex.: oncourt.onrender.com). Em dev pode ficar vazio.
CSRF_TRUSTED_ORIGINS=

# Banco. Vazio = SQLite local. Exemplos:
#   Postgres local:  postgres://oncourt:oncourt@localhost:5432/oncourt
#   Supabase:        postgres://postgres:[SENHA]@db.[REF].supabase.co:5432/postgres
#   AWS RDS:         postgres://USER:SENHA@HOST.rds.amazonaws.com:5432/DBNAME
DATABASE_URL=